@page
@model GitServer.wwwroot.IndexModel
@{
    ViewData["Title"] = "Home";
}
<div class="container">
    <div class="page-header">
        <h1>@L["index_recent_repos"]</h1>
        <div class="header-actions">
            <form method="get" action="/explore" class="search-form">
                <input name="q" type="search" class="form-control" placeholder="@L["search_placeholder"]" />
                <button type="submit" class="btn btn-secondary">@L["search_button"]</button>
            </form>
        </div>
    </div>

    @if (!Model.Repos.Any())
    {
        <div class="empty-state">
            <p>@L["index_empty"] <a href="/Repo/New">@L["index_empty_create"]</a></p>
        </div>
    }
    else
    {
        <div class="repo-list">
            @foreach (var repo in Model.Repos)
            {
                <div class="repo-card">
                    <div class="repo-card-header">
                        <a class="repo-name" href="/@repo.Owner.UserName/@repo.Name">
                            @repo.Owner.UserName / @repo.Name
                        </a>
                        <span class="badge @(repo.IsPrivate ? "badge-warning" : "badge-success")">
                            @(repo.IsPrivate ? L["badge_private"] : L["badge_public"])
                        </span>
                    </div>
                    @if (!string.IsNullOrEmpty(repo.Description))
                    {
                        <p class="repo-description">@repo.Description</p>
                    }
                    <div class="repo-meta">
                        <span class="text-muted">@L["updated_prefix"] @repo.UpdatedAt.ToString("d MMM yyyy")</span>
                    </div>
                </div>
            }
        </div>
    }
</div>
