@page "/Admin/Users"
@model GitServer.wwwroot.Admin.UsersModel
@{
    ViewData["Title"] = L["admin_users_title"];
}
<div class="container">
    <h1>@L["admin_users_title"]</h1>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-success">@Model.Message</div>
    }

    <table class="data-table">
        <thead>
            <tr>
                <th>@L["admin_col_user"]</th>
                <th>@L["email_label"]</th>
                <th>@L["admin_col_created"]</th>
                <th>@L["admin_col_admin"]</th>
                <th>@L["admin_col_actions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td><a href="/User/@user.UserName">@user.UserName</a></td>
                    <td>@user.Email</td>
                    <td>@user.CreatedAt.ToString("d MMM yyyy")</td>
                    <td>@if (user.IsAdmin) { <text>&#x2714;</text> }</td>
                    <td>
                        <form method="post" asp-page-handler="ToggleAdmin" style="display:inline">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-secondary">
                                @(user.IsAdmin ? L["admin_remove_admin"] : L["admin_make_admin"])
                            </button>
                        </form>
                        @if (user.Id != Model.CurrentUserId)
                        {
                            <form method="post" asp-page-handler="Delete" style="display:inline"
                                  onsubmit="return confirm('@L.Format("confirm_delete_user", user.UserName)')">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">@L["delete_button"]</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
