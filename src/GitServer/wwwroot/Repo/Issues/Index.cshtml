@page "/{user}/{repo}/issues"
@model GitServer.wwwroot.Repo.Issues.IssueIndexModel
@{
    ViewData["Title"] = $"Issues — {Model.UserName}/{Model.RepoName}";
}
<div class="container">
    <div class="repo-header">
        <div class="repo-title">
            <a href="/User/@Model.UserName">@Model.UserName</a> /
            <a href="/@Model.UserName/@Model.RepoName"><strong>@Model.RepoName</strong></a>
        </div>
    </div>

    @await Html.PartialAsync("_RepoNav", (Model.UserName, Model.RepoName, "issues"))

    <div class="issues-header">
        <div class="issues-filter">
            <a class="@(Model.ShowClosed ? "" : "active")"
               href="/@Model.UserName/@Model.RepoName/issues">@L["issues_open"]</a>
            <a class="@(Model.ShowClosed ? "active" : "")"
               href="/@Model.UserName/@Model.RepoName/issues?closed=1">@L["issues_closed"]</a>
        </div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="btn btn-primary" href="/@Model.UserName/@Model.RepoName/issues/new">@L["issues_new"]</a>
        }
    </div>

    @if (!Model.Issues.Any())
    {
        <div class="empty-state">
            @(Model.ShowClosed ? L["issues_empty_closed"] : L["issues_empty_open"])
        </div>
    }
    else
    {
        <div class="issue-list">
            @foreach (var issue in Model.Issues)
            {
                <div class="issue-item">
                    <span class="issue-state @(issue.IsClosed ? "state-closed" : "state-open")">
                        @(issue.IsClosed ? Html.Raw("&#x2716;") : Html.Raw("&#x2714;"))
                    </span>
                    <div class="issue-content">
                        <a class="issue-title" href="/@Model.UserName/@Model.RepoName/issues/@issue.Id">
                            @issue.Title
                        </a>
                        <span class="issue-meta text-muted">
                            #@issue.Id @L["issues_opened_by"] @issue.Author.UserName @L["issues_on"] @issue.CreatedAt.ToString("d MMM yyyy")
                            &nbsp;&middot; @issue.Comments.Count @L["issues_comments"]
                        </span>
                    </div>
                </div>
            }
        </div>
    }
</div>
