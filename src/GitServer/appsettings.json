{
  "GitServer": {
    "RepositoriesPath": "C:\\GitRepos",
    "GitExecutable": "git",
    "AllowRegistration": true,
    "RequireEmailConfirmation": false
  },
  "ConnectionStrings": {
    "Default": "Data Source=gitserver.db"
  },
  "OAuth": {
    "GitHub": {
      "ClientId": "",
      "ClientSecret": ""
    },
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
